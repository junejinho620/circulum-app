# App
NODE_ENV=development
PORT=3000
APP_SECRET=change-this-to-a-very-long-random-string

# Database
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=circulum
DB_PASSWORD=circulum_dev_password
DB_NAME=circulum_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_ACCESS_SECRET=access-secret-change-me
JWT_REFRESH_SECRET=refresh-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email (SMTP)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.circulum.app
SMTP_PASS=your-smtp-password
EMAIL_FROM=no-reply@circulum.app
EMAIL_FROM_NAME=Circulum

# Frontend URL (for email links)
FRONTEND_URL=https://circulum.app

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# File uploads (S3 compatible)
S3_BUCKET=circulum-media
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT=https://s3.amazonaws.com
