# Copy to .env and fill values before running docker-compose

NODE_ENV=development

# Database
DB_USERNAME=circulum
DB_PASSWORD=change_me_in_production
DB_NAME=circulum_db

# Redis
REDIS_PASSWORD=

# JWT (MUST be changed in production - use 64+ random chars)
JWT_ACCESS_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_SECURE_RANDOM_STRING

# Email (Mailgun/SendGrid/etc)
SMTP_HOST=smtp.mailgun.org
SMTP_PORT=587
SMTP_USER=postmaster@mg.yourdomain.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=no-reply@circulum.app
EMAIL_FROM_NAME=Circulum

# Frontend URL (for email verification links)
FRONTEND_URL=https://app.circulum.app
